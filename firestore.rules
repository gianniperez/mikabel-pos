rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isLoggedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // --- Products ---
    match /products/{prodId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn(); // Empleados pueden escanear nuevos
      allow update, delete: if isAdmin(); // Solo admin edita precios o stock a mano
    }

    // --- Categories ---
    match /categories/{catId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // --- Sales (Ventas y Subcolección Items) ---
    match /sales/{saleId} {
      allow create: if isLoggedIn();
      allow update: if isAdmin(); // Para marcarlas como Refunded
      allow read: if isAdmin() || resource.data.vendedoraId == request.auth.uid; // Empleado puede ver su historial de caja actual

      match /items/{itemId} {
         allow create, read: if isLoggedIn();
      }
    }

    // --- Cash Sessions (Cajas) ---
    match /cash_sessions/{sessionId} {
      allow create, update: if isLoggedIn();
      allow read: if isAdmin() || resource.data.employeeId == request.auth.uid;
    }

    // --- Cash Movements (Egresos) ---
    match /cash_movements/{movementId} {
      allow create: if isLoggedIn();
      allow read: if isAdmin() || resource.data.employeeId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Customers / Debts (Libreta de Fiados) ---
    match /customers/{custId} {
      allow read: if isLoggedIn();
      allow create, update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    match /debts/{debtId} {
       allow create, read, update: if isLoggedIn(); // Update para pasarlo a Paid (Abonar partial)
       allow delete: if isAdmin();
    }

  }
}
